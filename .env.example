# Copy to .env.local (recommended) and fill in values.
# Vite only exposes variables prefixed with VITE_.

# Base URL of your Puter Worker (must serve /api/projects/save|list|get)
# Example format (replace with your worker URL):
# VITE_PUTER_WORKER_URL=https://<your-worker-subdomain>.puter.site
VITE_PUTER_WORKER_URL=
